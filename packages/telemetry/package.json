{
  "version": "2.0.481",
  "description": "Observability for SpinaJS: Prometheus metrics, an HTTP request-timing/metrics middleware, and Apdex + rolling request stats",
  "main": "lib/cjs/index.js",
  "module": "lib/mjs/index.js",
  "exports": {
    ".": {
      "types": "./lib/mjs/index.d.ts",
      "import": "./lib/mjs/index.js",
      "require": "./lib/cjs/index.js"
    }
  },
  "type": "module",
  "private": false,
  "engines": {
    "node": ">=16.11"
  },
  "scripts": {
    "build": "npm run clean && npm run compile",
    "compile": "tsc -b tsconfig.mjs.json",
    "compile:cjs": "tsc -b tsconfig.cjs.json",
    "rimraf": "./node_modules/rimraf/bin.js",
    "clean": "rimraf lib/ && rimraf tsconfig.tsbuildinfo",
    "test": "ts-mocha --exit -p tsconfig.json test/**/*.test.ts",
    "coverage": "nyc npm run test",
    "build-docs": "rimraf docs && typedoc --options typedoc.json src/",
    "format": "prettier --write \"src/**/*.ts\"",
    "lint": "eslint -c .eslintrc.cjs --ext .ts src --fix",
    "preversion": "npm run lint",
    "version": "npm run format && git add -A src"
  },
  "author": "SpinaJS <spinajs@coderush.pl> (https://github.com/spinajs/log)",
  "license": "MIT",
  "name": "@spinajs/telemetry",
  "homepage": "https://github.com/spinajs/main#readme",
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "lib"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spinajs/main.git"
  },
  "bugs": {
    "url": "https://github.com/spinajs/main/issues"
  },
  "devDependencies": {
    "@spinajs/fs": "^2.0.481",
    "@spinajs/http-swagger": "^2.0.481"
  },
  "dependencies": {
    "@spinajs/configuration": "^2.0.481",
    "@spinajs/configuration-common": "^2.0.481",
    "@spinajs/di": "^2.0.481",
    "@spinajs/exceptions": "^2.0.481",
    "@spinajs/http": "^2.0.481",
    "@spinajs/log": "^2.0.481",
    "@spinajs/validation": "^2.0.481",
    "lodash": "^4.17.21",
    "prom-client": "^14.2.0"
  }
}
